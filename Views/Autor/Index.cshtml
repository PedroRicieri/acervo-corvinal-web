@model IEnumerable<BibliotecaWeb.Models.Autor>

@{
    ViewData["Title"] = "Autores Cadastrados";
}

<div class="container mt-4">
    <h2 class="mb-4 text-center fw-bold" style="color: var(--cor-primaria);">Autores do Acervo</h2>
    <hr class="mb-5" />

    <div class="row">
        @foreach (var autor in Model)
        {
            <div class="col-md-3 mb-4">
                <div class="card shadow-sm h-100 text-center p-4 border-0 bg-light">
                    <img src="@autor.Foto" class="rounded-circle mx-auto mb-3 shadow-sm" alt="Foto de @autor.Nome" style="width: 150px; height: 150px; object-fit: cover;">
                    <h5 class="fw-bold mb-2">@autor.Nome</h5>
                    <p class="text-muted small mb-3">@autor.DataNascimento</p>
                    <a href="@Url.Action("Detalhes", "Autor", new { id = autor.Id })" class="btn btn-sm btn-outline-secondary w-100 mt-auto">Ver Perfil e Obras</a>
                </div>
            </div>
        }
    </div>
</div>