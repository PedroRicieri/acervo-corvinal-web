@model BibliotecaWeb.Models.Livro

@{
    ViewData["Title"] = Model.Titulo;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-4">
            <img src="@Model.Capa" alt="Capa do livro @Model.Titulo" class="img-fluid rounded shadow">
        </div>
        <div class="col-md-8">
            <h2>@Model.Titulo</h2>
            <p class="text-muted">Ano de Publicação: @Model.AnoPublicacao</p>
            
            <h4 class="mt-4">Resumo</h4>
            <p>@Model.Resumo</p>

            <h4 class="mt-4">Autor</h4>
            <p>
                <strong>@Model.Autor?.Nome</strong> <br>
                <a href="@Url.Action("Detalhes", "Autor", new { id = Model.Autor?.Id })" class="btn btn-outline-secondary mt-2">Ver Perfil do Autor</a>
            </p>
        </div>
    </div>
    <div class="mt-4">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary">Voltar para a Página Inicial</a>
    </div>
</div>