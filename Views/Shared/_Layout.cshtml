<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Acervo Corvinal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/BibliotecaWeb.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/img/corvinal.png" alt="Símbolo Corvinal" style="height: 35px; margin-right: 10px;">
                    Acervo Corvinal
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold px-3" asp-area="" asp-controller="Home" asp-action="Index">Início</a>
                        </li>
                        
                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold px-3" asp-area="" asp-controller="Livro" asp-action="Index">Livros Cadastrados</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark fw-bold px-3" asp-area="" asp-controller="Autor" asp-action="Index">Autores</a>
                        </li>
                    </ul>

                    <form class="d-flex" asp-controller="Home" asp-action="Buscar" method="get">
                        <input class="form-control me-2" type="search" name="termo" placeholder="Pesquisar livro ou autor..." aria-label="Search">
                        <button class="btn btn-primary" type="submit">🔍</button>
                    </form>

                </div>
            </div>
        </nav>
    </header>
    
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted mt-5">
        <div class="container text-center">
            &copy; 2026 - Acervo Corvinal - Trabalho Prático 1
        </div>
    </footer>
    
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>