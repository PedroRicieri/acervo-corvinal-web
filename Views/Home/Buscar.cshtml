@model IEnumerable<BibliotecaWeb.Models.Livro>
@using BibliotecaWeb.Models

@{
    ViewData["Title"] = "Resultados da Busca";
}

<div class="container mt-4">
    <h2 class="mb-4">Resultados para: <span class="text-primary">"@ViewData["Termo"]"</span></h2>
    <hr class="mb-5" />

    <h4 class="mb-4">Livros Encontrados (@Model.Count())</h4>
    <div class="row mb-5">
        @if (Model.Any())
        {
            foreach (var livro in Model)
            {
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm h-100 border-0">
                        <img src="@livro.Capa" class="card-img-top rounded" alt="Capa de @livro.Titulo" style="height: 300px; object-fit: cover;">
                        <div class="card-body d-flex flex-column px-2">
                            <h6 class="card-title fw-bold">@livro.Titulo</h6>
                            <p class="card-text text-muted small mt-auto">Publicação: @livro.AnoPublicacao</p>
                            <a href="@Url.Action("Detalhes", "Livro", new { id = livro.Id })" class="btn btn-sm btn-outline-primary w-100 mt-2">Ver Detalhes do Livro</a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-light text-muted" role="alert">
                    Nenhum livro encontrado com o termo pesquisado.
                </div>
            </div>
        }
    </div>

    <h4 class="mb-4">Autores Encontrados (@(((List<Autor>)ViewBag.Autores).Count))</h4>
    <div class="row mb-5">
        @if (((List<Autor>)ViewBag.Autores).Any())
        {
            foreach (var autor in (List<Autor>)ViewBag.Autores)
            {
                <div class="col-md-3 mb-4">
                    <div class="card shadow-sm h-100 text-center p-4 border-0 bg-light">
                        <img src="@autor.Foto" class="rounded-circle mx-auto mb-3 shadow-sm" alt="Foto de @autor.Nome" style="width: 130px; height: 130px; object-fit: cover;">
                        <h6 class="fw-bold mb-3">@autor.Nome</h6>
                        <a href="@Url.Action("Detalhes", "Autor", new { id = autor.Id })" class="btn btn-sm btn-outline-secondary w-100 mt-auto">Ver Perfil do Autor</a>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-12">
                <div class="alert alert-light text-muted" role="alert">
                    Nenhum autor encontrado com o termo pesquisado.
                </div>
            </div>
        }
    </div>

    <div class="mt-4 text-center">
        <a href="@Url.Action("Index", "Home")" class="btn btn-primary px-4 py-2">Voltar para o Início</a>
    </div>
</div>